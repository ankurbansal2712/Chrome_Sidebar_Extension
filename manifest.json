{
  "manifest_version": 3,
  "name": " AI Chats Sidebar",
  "version": "1.0.0",
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
        ],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
  "activeTab",
  "tabs",
  "storage",
  "windows"
    ]
}